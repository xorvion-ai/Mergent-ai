# ── Mergent AI configuration ──────────────────────────────────────────
# Copy this file to ".env" and fill in values. Nothing here is required to
# run the app — without a key, Mergent uses its deterministic reasoning
# fallback so the demo is always free and never hard-fails.

# Google Gemini API key (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use for the "reason" half of each agent.
GEMINI_MODEL=gemini-3.1-flash-lite

# Free-tier daily call budget shown in the UI quota meter.
GEMINI_DAILY_BUDGET=1500

# Google OAuth client ID for "Sign in with Google" (public value; no secret needed).
# Create at console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID
# (Web app). Add your origins to "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=

# ── Magic-link email via Firebase Authentication (recommended) ───────
# Firebase sends the sign-in email for you — no SMTP, no password. Create a
# Firebase project (reuse your Google Cloud "Mergent" project), enable
# Authentication -> Sign-in method -> Email link (passwordless), register a
# Web app, and paste its (public) config here.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# ── OR: magic-link email via a transactional SMTP provider (fallback) ─
# Use a service like Brevo (300/day free), SendGrid (100/day), Resend, or
# Mailgun. Create an account, verify your sender address (xorvion.ai@gmail.com)
# by clicking their confirmation email, then create an SMTP / API key.
# SMTP_PASS is that generated key — NOT your personal email password.
# Leave blank to keep passwordless demo sign-in (no email sent).
#   Brevo:    SMTP_HOST=smtp-relay.brevo.com   SMTP_PORT=587
#   SendGrid: SMTP_HOST=smtp.sendgrid.net       SMTP_PORT=587  SMTP_USER=apikey
#   Resend:   SMTP_HOST=smtp.resend.com         SMTP_PORT=587  SMTP_USER=resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=xorvion.ai@gmail.com

# Stable secret for signing magic-link tokens (set any long random string in prod).
AUTH_SECRET=

# Server port.
PORT=3000

# Max upload size for zip intake, in MB.
MAX_UPLOAD_MB=200
